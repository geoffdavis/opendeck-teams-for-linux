{
	"Name": "Teams for Linux",
	"Author": "Geoff Davis",
	"Version": "0.1.1",
	"Category": "Teams",
	"Icon": "icons/plugin",
	"SDKVersion": 2,
	"OS": [{ "Platform": "linux" }],
	"CodePaths": {
		"x86_64-unknown-linux-gnu": "bin/plugin-x86_64",
		"aarch64-unknown-linux-gnu": "bin/plugin-aarch64"
	},
	"Actions": [
		{
			"UUID": "com.geoffdavis.teamsforlinux.toggle-mute",
			"Name": "Toggle Mute (Teams)",
			"Icon": "icons/icon",
			"Tooltip": "Toggle Microsoft Teams microphone mute via MQTT (teams-for-linux)",
			"Controllers": ["Keypad"],
			"DisableAutomaticStates": true,
			"PropertyInspectorPath": "pi/index.html",
			"States": [
				{ "Image": "icons/icon", "Title": "MIC", "FontSize": 18, "TitleColor": "#FFFFFF" },
				{ "Image": "icons/icon-muted", "Title": "MUTED", "FontSize": 18, "TitleColor": "#FF4040" }
			]
		},
		{
			"UUID": "com.geoffdavis.teamsforlinux.toggle-camera",
			"Name": "Toggle Camera (Teams)",
			"Icon": "icons/cam",
			"Tooltip": "Toggle Microsoft Teams camera via MQTT (teams-for-linux)",
			"Controllers": ["Keypad"],
			"DisableAutomaticStates": true,
			"PropertyInspectorPath": "pi/index.html",
			"States": [
				{ "Image": "icons/cam", "Title": "CAM", "FontSize": 18, "TitleColor": "#FFFFFF" },
				{ "Image": "icons/cam-off", "Title": "CAM OFF", "FontSize": 14, "TitleColor": "#FF4040" }
			]
		},
		{
			"UUID": "com.geoffdavis.teamsforlinux.toggle-hand-raise",
			"Name": "Toggle Hand Raise (Teams)",
			"Icon": "icons/hand",
			"Tooltip": "Raise or lower your hand in Microsoft Teams via MQTT (teams-for-linux). One-way toggle: Teams reports no hand-raise state to display.",
			"Controllers": ["Keypad"],
			"DisableAutomaticStates": true,
			"PropertyInspectorPath": "pi/index.html",
			"States": [
				{ "Image": "icons/hand", "Title": "HAND", "FontSize": 18, "TitleColor": "#FFFFFF" }
			]
		}
	]
}
